{
    "name": "jampak",
    "version": "1.0.9",
    "description": "JamPak file Encoder and Decoder",
    "main": "./dist/index.cjs.js",
    "module": "./dist/index.esm.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hearhellacopters/jampak.git"
    },
    "exports": {
        ".": {
            "require": "./dist/index.cjs.js",
            "import": "./dist/index.esm.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "npm run clean && rollup -c",
        "build:rollup": "npm run build",
        "build:ts": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:types",
        "build:esm": "tsc -p tsconfig.esm.json",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:types": "tsc -p tsconfig.d.ts.json",
        "clean": "rimraf dist"
    },
    "keywords": [
        "buffer",
        "parser",
        "reader",
        "json",
        "decode",
        "unpack",
        "struct"
    ],
    "author": "HearHellacopters",
    "license": "ISC",
    "devDependencies": {
        "@rollup/plugin-commonjs": "^28.0.6",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-replace": "^6.0.2",
        "@rollup/plugin-typescript": "^12.1.4",
        "@types/node": "^20.19.43",
        "rimraf": "^6.1.3",
        "rollup-plugin-dts": "^6.2.1",
        "rollup-plugin-polyfill-node": "^0.13.0",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "bireader": "^4.0.10",
        "cbor-x": "^1.6.4"
    },
    "engines": {
        "node": ">=18"
    },
    "allowScripts": {
        "cbor-extract@2.2.2": true
    }
}
